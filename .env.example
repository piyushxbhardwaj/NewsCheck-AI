# NewsCheck AI Configuration

# FastAPI Backend Settings
HOST=0.0.0.0
PORT=8000

# SQLite Database Location
DATABASE_PATH=database/newscheck.db

# LLM Configuration (OpenAI or any OpenAI-compatible provider)
# If using OpenAI:
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# If using a local LLM or alternative provider (e.g. Ollama, LM Studio, Groq, DeepSeek):
# OPENAI_API_BASE=http://localhost:11434/v1
# OPENAI_API_KEY=not-needed-for-local
# OPENAI_MODEL=llama3
# EMBEDDING_MODEL=all-minilm

# Search API Configurations
# Default falls back to free DuckDuckGo search. If you have Tavily, you can supply it:
TAVILY_API_KEY=

# Cache Settings (in hours)
CACHE_EXPIRY_HOURS=24
